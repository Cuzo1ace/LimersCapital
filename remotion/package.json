{
  "name": "limers-capital-demo-video",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion demo video for Limer's Capital — 4 variants: Walkthrough, Colosseum Pitch, Landing Loop, Social Teaser",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render:walkthrough": "remotion render src/index.ts WalkthroughFull out/walkthrough.mp4",
    "render:colosseum": "remotion render src/index.ts ColosseumPitch out/colosseum.mp4",
    "render:landing": "remotion render src/index.ts LandingLoop out/landing-loop.mp4",
    "render:social": "remotion render src/index.ts SocialTeaser out/social.mp4",
    "render:all": "npm run render:walkthrough && npm run render:colosseum && npm run render:landing && npm run render:social",
    "still": "remotion still src/index.ts",
    "voiceover": "node --experimental-strip-types src/scripts/generate-voiceover.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.322",
    "@remotion/cli": "^4.0.322",
    "@remotion/fonts": "^4.0.322",
    "@remotion/media-utils": "^4.0.322",
    "@remotion/transitions": "^4.0.322",
    "@remotion/zod-types": "^4.0.322",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.322",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.3"
  }
}
