/*
  # ── Security Headers — Limer's Capital ──
  # Deployed via Cloudflare Pages. Applies to all routes.

  # Prevent clickjacking — only allow our own frames
  X-Frame-Options: SAMEORIGIN

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Control referrer data leakage
  Referrer-Policy: strict-origin-when-cross-origin

  # Prevent XSS in older browsers
  X-XSS-Protection: 1; mode=block

  # DNS prefetch control
  X-DNS-Prefetch-Control: on

  # Permissions Policy — disable unnecessary browser APIs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()

  # Content Security Policy (enforced — current baseline)
  # This policy still allows 'unsafe-inline'/'unsafe-eval' for script-src so we
  # do not break the production bundle. The Report-Only policy below is the
  # hardened target; promote it to enforced after a 7-day zero-violation window.
  # Audit: C-03 Phase 1 (April 2026).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://us.i.posthog.com https://eu.i.posthog.com https://s3.tradingview.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://coin-images.coingecko.com https://assets.coingecko.com https://raw.githubusercontent.com https://*.helius-rpc.com https://s3.tradingview.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://hermes.pyth.network https://api.dexscreener.com https://api.jup.ag https://quote-api.jup.ag https://api.coingecko.com https://api.llama.fi https://stablecoins.llama.fi https://yields.llama.fi https://open.er-api.com https://api.worldbank.org https://*.helius-rpc.com https://ttse-proxy.solanacaribbean-team.workers.dev https://limer-api-proxy.solanacaribbean-team.workers.dev https://us.i.posthog.com https://eu.i.posthog.com https://api.allorigins.win wss://*.helius-rpc.com https://*.supabase.co wss://*.supabase.co https://uszaeqtrifenpibptvus.supabase.co wss://uszaeqtrifenpibptvus.supabase.co https://static.cloudflareinsights.com https://cloudflareinsights.com; frame-src https://defillama.com https://jup.ag https://s3.tradingview.com https://*.tradingview.com https://*.tradingview-widget.com https://birdeye.so https://*.birdeye.so; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';

  # Content Security Policy — Report-Only (hardened target — audit C-03 Phase 1)
  # Drops 'unsafe-inline' and 'unsafe-eval' from script-src so any inline script
  # injection (Ledger Connect Kit-class supply-chain attack) raises a violation
  # report. Inline boot-recovery script lives in /boot-recover.js (self-hosted)
  # and is pinned by SRI. 'wasm-unsafe-eval' is retained because several Solana
  # cryptography libs (@solana/web3.js, wallet adapters) compile WASM at runtime.
  # Violations POST to /csp-report on the Worker, which forwards to Sentry.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://us.i.posthog.com https://eu.i.posthog.com https://s3.tradingview.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://coin-images.coingecko.com https://assets.coingecko.com https://raw.githubusercontent.com https://*.helius-rpc.com https://s3.tradingview.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://hermes.pyth.network https://api.dexscreener.com https://api.jup.ag https://quote-api.jup.ag https://api.coingecko.com https://api.llama.fi https://stablecoins.llama.fi https://yields.llama.fi https://open.er-api.com https://api.worldbank.org https://*.helius-rpc.com https://ttse-proxy.solanacaribbean-team.workers.dev https://limer-api-proxy.solanacaribbean-team.workers.dev https://us.i.posthog.com https://eu.i.posthog.com https://api.allorigins.win wss://*.helius-rpc.com https://*.supabase.co wss://*.supabase.co https://uszaeqtrifenpibptvus.supabase.co wss://uszaeqtrifenpibptvus.supabase.co https://static.cloudflareinsights.com https://cloudflareinsights.com; frame-src https://defillama.com https://jup.ag https://s3.tradingview.com https://*.tradingview.com https://*.tradingview-widget.com https://birdeye.so https://*.birdeye.so; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests; report-uri https://limer-api-proxy.solanacaribbean-team.workers.dev/csp-report; report-to csp-endpoint;

  # Reporting API endpoint group (CSP v3) — mirrors the report-uri above
  Reporting-Endpoints: csp-endpoint="https://limer-api-proxy.solanacaribbean-team.workers.dev/csp-report"

  # Strict Transport Security (HTTPS only, 1 year, include subdomains)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
