# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── Cloudflare Worker — TTSE live stock data proxy ──────────────
# Proxies https://www.stockex.co.tt/ with CORS headers + 5-min edge cache.
# Already deployed: https://ttse-proxy.solanacaribbean-team.workers.dev
# Falls back to allorigins.win CORS proxy if not set.
VITE_TTSE_PROXY_URL=https://ttse-proxy.<your-subdomain>.workers.dev

# ── Custom Solana RPC endpoint (optional) ───────────────────────
# Falls back to public devnet/mainnet-beta RPC if not set.
# Must be HTTPS on a trusted domain: helius-rpc.com, quicknode.com, solana.com
# Free tier: https://dev.helius.xyz (sign up at helius.dev)
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
