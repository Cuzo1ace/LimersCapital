# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── API Proxy (RECOMMENDED for production) ──────────────────────
# Routes all Helius/CoinGecko calls through a Cloudflare Worker.
# The Helius API key stays server-side — never exposed to the browser.
# Deploy: cd workers && wrangler deploy api-proxy.js -c wrangler-api.toml
# Then:   wrangler secret put HELIUS_API_KEY -c wrangler-api.toml
VITE_API_PROXY_URL=https://limer-api-proxy.<your-subdomain>.workers.dev

# ── Cloudflare Worker — TTSE live stock data proxy ──────────────
# Proxies https://www.stockex.co.tt/ with CORS headers + 5-min edge cache.
# Deploy: cd workers && wrangler deploy ttse-proxy.js
VITE_TTSE_PROXY_URL=https://ttse-proxy.<your-subdomain>.workers.dev

# ── Direct Solana RPC (local dev only — DO NOT use in production) ──
# In production, all RPC calls go through VITE_API_PROXY_URL.
# For local dev without the proxy, you can set a direct Helius RPC URL:
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#
# WARNING: VITE_ prefixed vars are embedded in the JS bundle.
# NEVER deploy to production with VITE_HELIUS_API_KEY or VITE_SOLANA_RPC_URL
# containing an API key — use the proxy instead.

# ── Supabase ────────────────────────────────────────────────────
# Public anon key — safe for client bundles (RLS protects data).
# Get both from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Analytics (optional) ────────────────────────────────────────
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Error telemetry (REQUIRED in production — audit C-02) ───────
# Sentry captures unhandled exceptions, React ErrorBoundary crashes, and
# Worker-side upstream failures. Without a DSN, every error is silent and
# mean-time-to-detection is whatever "a user reports the site is broken"
# takes. See docs/SECURITY.md §10 for the full activation runbook.
#
# Provisioning (one-time, ~15 min):
#   1. Create a React project at https://sentry.io → copy the DSN.
#   2. Frontend: paste the DSN into Cloudflare Pages → Settings →
#      Environment variables as `VITE_SENTRY_DSN`. Trigger a redeploy.
#   3. Worker: from workers/, run
#        npx wrangler secret put SENTRY_DSN -c wrangler-api.toml
#      and paste the SAME DSN.
#   4. Smoke test: open the production site, click the hidden "throw
#      Sentry test" button in the footer. Confirm the event appears in
#      the Sentry dashboard within 30 seconds.
#
# Format: https://<publicKey>@<host>/<projectId>
VITE_SENTRY_DSN=
# Optional release tag (auto-populated by the CI build step when set):
# VITE_GIT_SHA=
# Optional environment override — defaults to Vite's import.meta.env.MODE:
# VITE_SENTRY_ENVIRONMENT=production
