# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── API Proxy (RECOMMENDED for production) ──────────────────────
# Routes all Helius/CoinGecko calls through a Cloudflare Worker.
# The Helius API key stays server-side — never exposed to the browser.
# Deploy: cd workers && wrangler deploy api-proxy.js -c wrangler-api.toml
# Then:   wrangler secret put HELIUS_API_KEY -c wrangler-api.toml
VITE_API_PROXY_URL=https://limer-api-proxy.<your-subdomain>.workers.dev

# ── Cloudflare Worker — TTSE live stock data proxy ──────────────
# Proxies https://www.stockex.co.tt/ with CORS headers + 5-min edge cache.
# Deploy: cd workers && wrangler deploy ttse-proxy.js
VITE_TTSE_PROXY_URL=https://ttse-proxy.<your-subdomain>.workers.dev

# ── Direct Solana RPC (local dev only — DO NOT use in production) ──
# In production, all RPC calls go through VITE_API_PROXY_URL.
# For local dev without the proxy, you can set a direct Helius RPC URL:
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#
# WARNING: VITE_ prefixed vars are embedded in the JS bundle.
# NEVER deploy to production with VITE_HELIUS_API_KEY or VITE_SOLANA_RPC_URL
# containing an API key — use the proxy instead.

# ── Analytics (optional) ────────────────────────────────────────
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
