# Force npm to accept legacy peer-dep resolutions. Required because
# vite-plugin-pwa@1.2.0 only declares support for vite@^3..^7, and
# the project uses vite@8. Without this, `npm ci` (which Cloudflare
# Workers Builds runs before our Build command) fails with ERESOLVE.
#
# Both `npm install` and `npm ci` respect this setting. If the peer
# dep is ever properly resolved upstream, delete this file.
legacy-peer-deps=true
